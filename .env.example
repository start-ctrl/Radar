# Environment template - copy to .env and fill in your values
# Never commit .env with real secrets

# Apollo API Configuration
APOLLO_API_KEY=your_apollo_api_key_here

# Resend Email Configuration
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=notifications@yourdomain.com
EMAIL_TO=admin@yourdomain.com

# Authentication (use strong password in production)
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=your_secure_password_here

# Service Configuration
PEOPLE_DATA_PROVIDER=apollo
NOTIFICATION_PROVIDER=resend

# Database
DATABASE_URL=sqlite:///./founder_tracker.db

# Scheduler
INGESTION_CRON=0 2 * * *
DETECTION_CRON=0 3 * * *
